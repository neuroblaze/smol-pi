#!/bin/sh
# smol-pi-build: build a smol-pi sandbox image and export it as a tar for
# smolvm to boot.
#
# Usage:
#   smol-pi-build                       # build the default image (pi)
#   smol-pi-build rust                  # build Dockerfile.rust -> rust.tar
#   smol-pi-build -f <path>             # build a custom Dockerfile
#   smol-pi-build --generate-dockerfile # write the default Dockerfile to CWD
#
# The image name is derived from the positional argument: 'rust' builds
# Dockerfile.rust and writes rust.tar. With no argument, Dockerfile.pi is
# built and pi.tar is written (falling back to pi-sandbox.tar for backward
# compatibility with pre-v1.1.0 installs).
#
# Prefers podman (rootless, daemonless) over docker if available.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Resolve the data directory: in installed mode, data files live in
# $PREFIX/etc/smol-pi (i.e. $SCRIPT_DIR/../etc/smol-pi). In dev/repo mode,
# they live next to this script in $SCRIPT_DIR. Pick whichever exists.
DATA_DIR=""
if [ -d "$SCRIPT_DIR/../etc/smol-pi" ]; then
  DATA_DIR="$(cd "$SCRIPT_DIR/../etc/smol-pi" && pwd)"
elif [ -d "$SCRIPT_DIR" ]; then
  DATA_DIR="$(cd "$SCRIPT_DIR" && pwd)"
fi

IMAGE_NAME="pi"
DOCKERFILE=""
GENERATE=0

usage() {
  cat <<USAGE
smol-pi-build: build a smol-pi sandbox image and export a tar for smolvm

Usage:
  smol-pi-build [<name>]               Build Dockerfile.<name> -> <name>.tar
                                        (default name: pi -> Dockerfile.pi)
  smol-pi-build -f <path>              Build a custom Dockerfile (name: pi)
  smol-pi-build --generate-dockerfile  Write the default Dockerfile.pi to CWD

Options:
  -f <path>           Build a custom Dockerfile instead of Dockerfile.<name>
  --generate-dockerfile  Write the default Dockerfile to ./Dockerfile.pi
  --help, -h          Show this help

The build uses podman if available, otherwise docker.
The output tar is written to the smol-pi data directory as <name>.tar.
Use 'smol-pi --image <name>' to launch it.
USAGE
}

while [ $# -gt 0 ]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    -f)
      if [ $# -lt 2 ]; then
        echo "smol-pi-build: -f requires a path argument" >&2
        exit 2
      fi
      DOCKERFILE="$2"
      shift 2
      ;;
    -f=*)
      DOCKERFILE="${1#-f=}"
      shift
      ;;
    --generate-dockerfile)
      GENERATE=1
      shift
      ;;
    -*)
      echo "smol-pi-build: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      IMAGE_NAME="$1"
      shift
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Detect container tool: prefer podman (rootless), fall back to docker.
# ---------------------------------------------------------------------------
if command -v podman >/dev/null 2>&1; then
  CT=podman
elif command -v docker >/dev/null 2>&1; then
  CT=docker
else
  echo "smol-pi-build: neither podman nor docker found on PATH." >&2
  echo "smol-pi-build: install one of:" >&2
  echo "  podman  (rootless, no daemon) — https://podman.io/docs/installation" >&2
  echo "  docker  (requires dockerd)    — https://docs.docker.com/engine/install/" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Handle --generate-dockerfile: write the default Dockerfile to CWD.
# ---------------------------------------------------------------------------
# The default Dockerfile is embedded below so this script is self-contained.
write_default_dockerfile() {
  target="$1"
  if [ -f "$target" ]; then
    echo "smol-pi-build: refusing to overwrite existing $target" >&2
    echo "smol-pi-build: remove it first if you want a fresh copy." >&2
    exit 1
  fi
  cat > "$target" <<'DOCKERFILE'
FROM node:24-trixie-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
       bash ca-certificates coreutils curl file findutils git gnupg \
       iproute2 iputils-ping iputils-tracepath jq less \
       make openssh-client procps ripgrep rsync \
       sudo tar unzip vim xz-utils zstd \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g --ignore-scripts @earendil-works/pi-coding-agent

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

RUN printf '%s\n' \
    '#!/bin/sh' \
    '# smol-pi entrypoint: optionally rewrite DNS, set TTY size, cd to /workspace,' \
    '# then exec.' \
    '# smolvm allocates the PTY at 24x80 by default. If COLUMNS/LINES env vars are' \
    '# set (passed from the host terminal via smol-pi), resize the PTY to match.' \
    '# This only affects the initial size — terminal resize signals still work.' \
    'if [ -n "$SMOL_PI_DNS" ]; then' \
    '  echo "nameserver $SMOL_PI_DNS" > /etc/resolv.conf' \
    'fi' \
    'if [ -n "$COLUMNS" ] && [ -n "$LINES" ]; then' \
    '  stty rows "$LINES" cols "$COLUMNS" 2>/dev/null' \
    'fi' \
    'cd /workspace 2>/dev/null || true' \
    'exec "$@"' \
  > /usr/local/bin/smol-pi-entrypoint \
  && chmod +x /usr/local/bin/smol-pi-entrypoint

WORKDIR /workspace
ENTRYPOINT ["pi"]
DOCKERFILE
  echo "smol-pi-build: wrote default Dockerfile to $target"
}

if [ "$GENERATE" -eq 1 ]; then
  write_default_dockerfile "./Dockerfile.pi"
  exit 0
fi

# ---------------------------------------------------------------------------
# Resolve which Dockerfile to build.
#
# Precedence:
#   1. -f <path>  — explicit Dockerfile path (image name stays 'pi' unless
#      overridden by a later positional arg; -f is rarely combined with a
#      name, but if both are given the name wins for the output tarball).
#   2. Positional <name> — Dockerfile.<name> in the data directory.
#   3. Default — Dockerfile.pi in the data directory.
# ---------------------------------------------------------------------------
if [ -n "$DOCKERFILE" ]; then
  # User-supplied path (may be relative to CWD or absolute).
  if [ ! -f "$DOCKERFILE" ]; then
    echo "smol-pi-build: Dockerfile not found: $DOCKERFILE" >&2
    exit 1
  fi
  BUILD_CONTEXT="$(dirname "$DOCKERFILE")"
  BUILD_FILE="$DOCKERFILE"
else
  BUILD_FILE="$DATA_DIR/Dockerfile.$IMAGE_NAME"
  if [ ! -f "$BUILD_FILE" ]; then
    echo "smol-pi-build: Dockerfile not found: $BUILD_FILE" >&2
    echo "smol-pi-build: create it, or generate the default with: smol-pi-build --generate-dockerfile" >&2
    exit 1
  fi
  BUILD_CONTEXT="$DATA_DIR"
fi

# Container image tag: namespaced to avoid collisions with other images.
IMAGE_TAG="pi-sandbox-$IMAGE_NAME"
# Output tarball: <name>.tar in the data directory.
TARBALL="$IMAGE_NAME.tar"

# ---------------------------------------------------------------------------
# Build and export.
# ---------------------------------------------------------------------------
echo "==> Building image '$IMAGE_NAME' with $CT (Dockerfile: $BUILD_FILE)"
$CT build --no-cache -t "$IMAGE_TAG" -f "$BUILD_FILE" "$BUILD_CONTEXT"

echo "==> Exporting to $TARBALL"
rm -f "$DATA_DIR/$TARBALL"
$CT save "$IMAGE_TAG" -o "$DATA_DIR/$TARBALL"

# Clean up orphaned smolvm image archives from previous builds.
# smolvm caches image tarballs content-addressed by hash in
# ~/.cache/smolvm-image-archives/. We keep archives matching any .tar
# currently in the data dir (so rebuilding one image doesn't orphan
# another image's archive).
ARCHIVES_DIR="$HOME/.cache/smolvm-image-archives"
if [ -d "$ARCHIVES_DIR" ]; then
  # Build a newline-separated list of current tarball hashes.
  current_hashes=""
  for tar in "$DATA_DIR"/*.tar; do
    [ -f "$tar" ] || continue
    h=$(sha256sum "$tar" 2>/dev/null | cut -d' ' -f1)
    [ -n "$h" ] && current_hashes="$current_hashes
$h"
  done
  removed=0
  for dir in "$ARCHIVES_DIR"/*/; do
    [ -d "$dir" ] || continue
    hash=$(basename "$dir")
    case "$current_hashes" in
      *"$hash"*) continue ;;
    esac
    rm -rf "$dir"
    removed=$((removed + 1))
  done
  if [ "$removed" -gt 0 ]; then
    echo "==> Cleaned up $removed orphaned smolvm image archive(s)"
  fi
fi

echo "==> Done. Run with: smol-pi --image $IMAGE_NAME"